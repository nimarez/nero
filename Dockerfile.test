FROM ghcr.io/astral-sh/uv:0.9.22 AS uv

FROM python:3.10-slim

COPY --from=uv /uv /uvx /bin/

ENV DEBIAN_FRONTEND=noninteractive \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

RUN apt-get update -qq \
    && apt-get install -y -qq --no-install-recommends \
       libegl1 libgl1 libglib2.0-0 libglu1-mesa libglx0 libice6 libopengl0 \
       libsm6 libx11-6 libxext6 \
    && apt-get clean

WORKDIR /app
COPY . .

RUN uv sync --all-groups --locked \
    && uv run nero-setup-orbslam --output /opt/nero/ORBvoc.txt

CMD ["sh", "-c", "uv run ruff check . && uv run pytest -q && uv run python scripts/native_slam_smoke.py /opt/nero/ORBvoc.txt"]
